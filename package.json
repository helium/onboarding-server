{
  "name": "onboarding-server",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "nodemon -r dotenv/config --exec babel-node ./src/server.js",
    "build": "babel src --out-dir build --copy-files",
    "start": "node build/server.js",
    "clean": "rimraf build",
    "db:create": "npx sequelize-cli db:create",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "task": "DISABLE_DB_LOGGING=true node -r dotenv/config"
  },
  "dependencies": {
    "@babel/cli": "^7.12.10",
    "@babel/core": "^7.12.10",
    "@babel/node": "^7.12.10",
    "@babel/plugin-transform-runtime": "^7.12.10",
    "@babel/preset-env": "^7.12.11",
    "@fnando/keyring": "^0.4.0",
    "@helium/account-fetch-cache": "^0.11.4",
    "@helium/address": "^5.0.4",
    "@helium/crypto": "^5.0.4",
    "@helium/data-credits-sdk": "^0.11.4",
    "@helium/helium-entity-manager-sdk": "^0.11.4",
    "@helium/helium-sub-daos-sdk": "^0.11.4",
    "@helium/http": "^5.0.4",
    "@helium/spl-utils": "^0.11.4",
    "@helium/transactions": "^5.0.4",
    "@metaplex-foundation/mpl-bubblegum": "^0.7.0",
    "@noble/ed25519": "^2.1.0",
    "@project-serum/anchor": "^0.25.0",
    "@solana/spl-account-compression": "^0.1.5",
    "@solana/web3.js": "^1.98.4",
    "aws-sdk": "^2.1318.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "camelcase-keys": "^6.2.2",
    "compression": "^1.7.4",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^8.2.0",
    "express": "^4.21.2",
    "express-basic-auth": "^1.2.0",
    "express-rate-limit": "^5.2.3",
    "ioredis": "^4.19.4",
    "morgan": "^1.10.0",
    "pg": "^8.5.1",
    "pg-hstore": "^2.3.4",
    "prompts": "^2.4.2",
