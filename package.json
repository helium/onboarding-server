    "base-x": "^3.0.11",
    "braces": "^3.0.3",
    "cross-spawn": "^7.0.5",
    "minimatch": "^3.1.4",
    "underscore": "^1.13.8",
    "validator": "^13.15.22",
    "ws": "^7.5.10"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prettier": "^2.2.1",
